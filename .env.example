# Plato — example environment variables
#
# Copy to .env (or .env.local) and fill in the keys you want to use.
# Plato reads these at import time and again on each KeyManager
# refresh; values stored via the dashboard /keys UI take precedence
# only when the env var is unset.
#
# All variables are optional — Plato will run in demo mode when
# every LLM provider key is missing. Empty strings are treated as
# unset.

# ───────────────────────────────────────────────────────────────
# LLM providers (at least one is needed for any real workflow)
# ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=

# Some Google integrations expect a JSON service-account file.
# Set this to the absolute path of that file when needed.
GOOGLE_APPLICATION_CREDENTIALS=

# ───────────────────────────────────────────────────────────────
# Retrieval — domain adapters in plato/retrieval/sources/
# ───────────────────────────────────────────────────────────────
SEMANTIC_SCHOLAR_KEY=
ADS_API_KEY=
ADS_DEV_KEY=
NCBI_API_KEY=
FUTURE_HOUSE_API_KEY=

# Optional Cohere reranker (plato/retrieval/reranker.py). When unset,
# rerank() falls through to the cross-encoder backend or no-op pass.
COHERE_API_KEY=

# Optional MeSH vocabulary file path for the biology keyword extractor
# (plato/keyword_extractor/mesh.py). When unset, the extractor falls
# back to plain frequency tokenisation — fine for demos, not great for
# real PubMed retrieval.
PLATO_MESH_VOCAB=

# Plato logger verbosity. Honoured by plato/logging_config.py at module
# import; defaults to INFO when unset. Examples: DEBUG, INFO, WARNING.
PLATO_LOG_LEVEL=

# ───────────────────────────────────────────────────────────────
# Observability (R8)
# ───────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ───────────────────────────────────────────────────────────────
# Dashboard runtime
# ───────────────────────────────────────────────────────────────
PLATO_HOST=127.0.0.1
PLATO_PORT=7878

# Multi-tenant mode: when set to "1", every dashboard request must
# carry the X-Plato-User header. Defaults to single-user mode.
PLATO_DASHBOARD_AUTH_REQUIRED=0

# Override the project root (defaults to ~/.plato/projects).
# In multi-tenant mode, projects are nested under
# <PLATO_PROJECT_ROOT>/users/<user_id>/.
PLATO_PROJECT_ROOT=

# Override the encrypted key store location (defaults to ~/.plato/keys.json).
PLATO_KEYS_PATH=

# Demo mode hides the in-app key entry UI and capabilities banner.
PLATO_DEMO_MODE=0

# Disable the on-disk retrieval ETag cache (useful for tests).
PLATO_DISABLE_RETRIEVAL_CACHE=0

# Hard cost cap for the nightly evaluation workflow (USD).
PLATO_EVAL_MAX_USD=20

# ───────────────────────────────────────────────────────────────
# Dashboard worker / SSE runtime (read by plato_dashboard.settings)
# ───────────────────────────────────────────────────────────────
# Redis URL for the arq worker queue and any future cross-worker SSE
# fan-out. Leave blank to use the in-memory fakeredis fallback (the
# default for local + Spaces deploys).
PLATO_REDIS_URL=

# When "true", force the in-memory Redis fallback even if PLATO_REDIS_URL
# is set. Defaults to true so the demo image stays single-process.
PLATO_USE_FAKEREDIS=true

# arq worker concurrency (jobs per worker process). Default 4.
PLATO_WORKER_CONCURRENCY=

# Maximum concurrent runs per local-mode session.
PLATO_LOCAL_MAX_CONCURRENT_RUNS=

# Demo-mode session controls (only consumed when PLATO_DEMO_MODE=enabled).
PLATO_DEMO_SESSION_BUDGET_CENTS=
PLATO_DEMO_SESSION_IDLE_MINUTES=
PLATO_DEMO_MAX_CONCURRENT_RUNS=
PLATO_DEMO_ALLOWED_STAGES=

# Comma-separated list of CORS origins for the FastAPI gateway.
PLATO_CORS_ORIGINS=

# ───────────────────────────────────────────────────────────────
# Optional alt auth env-var spelling
# (the legacy single-user code path still reads PLATO_AUTH=enabled)
# ───────────────────────────────────────────────────────────────
PLATO_AUTH=
