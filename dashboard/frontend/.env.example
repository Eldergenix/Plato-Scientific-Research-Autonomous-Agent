# Dashboard frontend — example environment variables
#
# Copy to .env.local. Only NEXT_PUBLIC_* variables are exposed to
# the browser; everything else lives in the backend's .env.

# Base URL of the dashboard FastAPI backend. Override when the
# backend runs on a different host/port (e.g. behind a reverse proxy).
NEXT_PUBLIC_API_BASE=http://127.0.0.1:7878/api/v1

# Hosted Clerk mode. Leave unset for the open-source/self-hosted default.
# When enabled, Clerk authenticates scientists, Clerk Organizations are shown
# as Labs, and the Next.js API proxy derives X-Plato-User from the signed-in
# user or active Lab before forwarding requests to FastAPI.
# NEXT_PUBLIC_PLATO_AUTH_PROVIDER=clerk
# PLATO_AUTH_PROVIDER=clerk
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Clerk Billing / trial guard configuration.
# NEXT_PUBLIC_PLATO_HOSTED_BILLING=enabled
# PLATO_HOSTED_TRIAL_PUBLICATIONS_PER_WEEK=2
# PLATO_HOSTED_USAGE_LEDGER_PATH=~/.plato/hosted-usage/weekly-publications.json
