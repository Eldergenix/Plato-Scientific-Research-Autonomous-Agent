# Dashboard frontend — example environment variables
#
# Copy to .env.local. Only NEXT_PUBLIC_* variables are exposed to
# the browser; everything else lives in the backend's .env.

# Base URL of the dashboard FastAPI backend for browser-side reads.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:7878/api/v1

# Internal backend origin used by the Next.js API proxy and hosted billing
# server reads. Set this when FastAPI is private or on a different host.
# PLATO_API_PROXY_TARGET=http://127.0.0.1:7878
#
# Optional canonical public origin for hosted redirects and Clerk proxy URLs.
# Set this on production deployments so sign-in return URLs and Clerk proxy
# metadata cannot be influenced by forwarded-host headers.
# PLATO_PUBLIC_ORIGIN=https://discovering.app

# Hosted Clerk mode. Leave unset for the open-source/self-hosted default.
# When enabled, Clerk authenticates scientists, Clerk Organizations are shown
# as Labs, and the Next.js API proxy derives X-Plato-User from the signed-in
# user or active Lab before forwarding requests to FastAPI.
# NEXT_PUBLIC_PLATO_AUTH_PROVIDER=clerk
# PLATO_AUTH_PROVIDER=clerk
# PLATO_BACKEND_PROXY_SECRET=generate-at-least-32-random-characters
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_PROXY_URL=https://discovering.app/__clerk
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Clerk Billing / trial guard configuration.
# NEXT_PUBLIC_PLATO_HOSTED_BILLING=enabled
# PLATO_HOSTED_TRIAL_PUBLICATIONS_PER_WEEK=2
# PLATO_HOSTED_USER_PRO_FEE_CENTS=1499
# PLATO_HOSTED_USER_RESEARCHER_FEE_CENTS=9999
# PLATO_HOSTED_LAB_BASE_FEE_CENTS=9900
# PLATO_HOSTED_LAB_SEAT_FEE_CENTS=0
# PLATO_HOSTED_USAGE_LEDGER_PATH=~/.plato/hosted-usage/weekly-publications.json
