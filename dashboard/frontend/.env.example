# Dashboard frontend — example environment variables
#
# Copy to .env.local. Only NEXT_PUBLIC_* variables are exposed to
# the browser; everything else lives in the backend's .env.

# Base URL of the dashboard FastAPI backend. Override when the
# backend runs on a different host/port (e.g. behind a reverse proxy).
NEXT_PUBLIC_API_BASE=http://127.0.0.1:7878/api/v1
